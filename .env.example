# Copy this file to .env and fill in your values.
# .env is excluded from git — never commit real credentials.

PGUSER=postgres
PGHOST=localhost
PGDATABASE=candidate_db
PGPASSWORD=your_password_here
PGPORT=5432

# Path to LookerDashboard.html relative to server.js.
# Only needed when backend and frontend are in separate directories.
# Example (backend/ alongside frontend/src/):
# LOOKER_DASHBOARD_PATH=../frontend/src/LookerDashboard.html

# Flask secret key (webbridge.py). REQUIRED — webbridge.py will refuse to start
# if this is not set or left as the default placeholder.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-strong-random-value

# Comma-separated list of allowed CORS origins for webbridge.py.
# Defaults to localhost origins if not set.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:8091

# Set to "1" when running behind HTTPS to enable Secure cookie flag (webbridge.py).
# FORCE_HTTPS=0

# Set to "production" to enable Secure cookie flag in server.js.
# NODE_ENV=production
